# Copy to .env. Used by: python -m ai_events run | export | db apply-schema | serve

# Local Docker (docker compose up -d):
# DATABASE_URL=postgresql://events:events@127.0.0.1:5432/events
# DATABASE_SSL=false

# Neon: create a project at https://console.neon.tech — use the connection string
# (pooled host recommended for serverless). Omit DATABASE_SSL; the app uses TLS
# for non-localhost URLs.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Integration tests (pytest) TRUNCATE the events table — use a separate DB or Neon branch:
# TEST_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB_TEST?sslmode=require
# Apply schema once to that database: DATABASE_URL="$TEST_DATABASE_URL" python -m ai_events db apply-schema

# --- Enterprise LLM filter (Eventbrite, Meetup, techUK, google_search; after keyword filters) ----------
# Off by default. Set to 1 to enable (experimental; requires local OpenAI-compatible server).
# ENTERPRISE_LLM_ENABLED=1
# ENTERPRISE_LLM_BASE_URL=http://127.0.0.1:11434/v1
# ENTERPRISE_LLM_MODEL=llama3.2
# ENTERPRISE_LLM_TIMEOUT=120
# optional: ENTERPRISE_LLM_API_KEY=...  # if your gateway requires a Bearer token

# --- Semantic search (API /api/events?q=) — pgvector + Ollama embeddings --------------------------
# On by default. Set SEMANTIC_SEARCH=0 to force keyword full-text only.
# SEMANTIC_SEARCH=1
# Ollama: ollama pull nomic-embed-text
# EMBEDDINGS_BASE_URL=http://127.0.0.1:11434
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIM=768
# EMBEDDING_HTTP_TIMEOUT=90
# After schema apply: python -m ai_events db backfill-embeddings
